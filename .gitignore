# from https://newbedev.com/how-do-i-add-files-without-dots-in-them-all-extension-less-files-to-the-gitignore-file
# to ignore all files without extensions (binary files)
*
!/**/
!*.*

/screenshots/
/docs/
/lib/
/bin/
# Build scratch (AppImage AppDir, downloaded linuxdeploy/appimagetool, the .AppImage
# output). A single dir-ignore beats per-pattern rules — and is required here because
# the "!*.*" rule above would otherwise force-track every dotted artifact (*.so.6,
# *.AppImage, *.png, *.desktop) inside it. Keep all transient build output under temp/.
/temp/
/.shards/
/shard.override.yml
*.dwarf
imgui.ini
/coverage/
/doc/obsidian/embrace/.obsidian/
generated-error*
.~*
dump_*.txt
*.embrace
*.exe
*.res
gc.dll
iconv-2.dll
embrace.license
pki-root-ca.json
/node_modules/
/package.json
/package-lock.json
/.claude/

# pre-push-Hook (extensionslos, sonst von "*" oben ignoriert)
!/scripts/githooks/pre-push
shard.lock
